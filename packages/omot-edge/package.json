{
  "name": "omot-edge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "cf:r2:create": "wrangler r2 bucket create omot-cache",
    "cf:d1:create": "wrangler d1 create omot-db",
    "cf:d1:migrate": "wrangler d1 migrations apply omot-db"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250508.0",
    "@cloudflare/vitest-pool-workers": "^0.8.7",
    "typescript": "^5.5.0",
    "vitest": "^2.1.1",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "twitter-data-parser": "^1.0.0"
  }
}
